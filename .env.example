# --- AI — asosiy ---
# Telefon uchun: .env ni assets/ai.env ga nusxalang, keyin flutter build apk
AI_PROVIDER=gemini
AI_FALLBACK_ORDER=openai,openrouter,groq,cloudflare
AI_REQUEST_TIMEOUT_MS=90000
AI_MAX_RETRIES=2
AI_RETRY_DELAY_MS=1500
BOT_DEBUG_LOGS=false

# --- Gemini ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite,gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192

# --- OpenAI zaxira ---
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_FALLBACKS=gpt-4o,gpt-4.1-mini,gpt-4.1-nano

# --- OpenRouter zaxira ---
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_MODEL_FALLBACKS=openai/gpt-4o-mini,openai/gpt-4o
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_X_TITLE=REJABON AI

# --- Cloudflare zaxira ---
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct
CLOUDFLARE_AI_MODEL_FALLBACKS=@cf/qwen/qwen1.5-14b-chat-awq,@cf/mistral/mistral-7b-instruct-v0.2

# --- Groq zaxira ---
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_FALLBACKS=llama-3.1-70b-versatile,gemma2-9b-it
