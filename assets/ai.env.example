# REJABON AI — AI configuration template
# Copy to project root as .env (gitignored) for local development.
# Release builds: pass keys via --dart-define (never bundle real keys):
# flutter build apk --dart-define=GEMINI_API_KEY=your_key --dart-define=GEMINI_MODEL=gemini-2.0-flash-lite

AI_PROVIDER=gemini
AI_FALLBACK_ORDER=openai,openrouter,groq,cloudflare
AI_REQUEST_TIMEOUT_MS=90000
AI_MAX_RETRIES=2
AI_RETRY_DELAY_MS=1500
BOT_DEBUG_LOGS=false

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=8192

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
